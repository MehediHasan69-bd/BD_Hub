<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jisan | Gaming & Crypto</title>
    <style>
        :root {
            --bg: #0b0e11;
            --card: #1e2329;
            --neon: #00ffcc;
            --text: #eaecef;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
        }

        /* Profile Header */
        .profile-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 3px solid var(--neon);
            margin-bottom: 10px;
            box-shadow: 0 0 15px rgba(0, 255, 204, 0.3);
        }

        /* Crypto Dashboard */
        .dashboard {
            display: flex;
            gap: 15px;
            width: 100%;
            max-width: 400px;
            margin-bottom: 30px;
        }

        .crypto-card {
            background: var(--card);
            flex: 1;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            border-bottom: 3px solid var(--neon);
        }

        .price {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--neon);
            margin-top: 5px;
        }

        /* Buttons/Links */
        .link-tree {
            width: 100%;
            max-width: 400px;
        }

        .btn {
            display: block;
            background: var(--card);
            color: var(--text);
            text-decoration: none;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 8px;
            text-align: center;
            transition: 0.3s;
            border: 1px solid #333;
        }

        .btn:active {
            transform: scale(0.98);
            background: #2b3139;
        }

        .btn span { color: var(--neon); margin-right: 10px; }

        .loading { font-size: 0.8rem; opacity: 0.6; }
    </style>
</head>
<body>

    <div class="profile-header">
        <div class="avatar"></div> <h1>ᴊɪsᴀɴ ɢᴀᴍɪɴɢ</h1>
        <p>Rusher | Crypto Enthusiast | Anime Fan</p>
    </div>

    <div class="dashboard">
        <div class="crypto-card">
            <small>BTC/USD</small>
            <div id="btc" class="loading">Fetching...</div>
        </div>
        <div class="crypto-card">
            <small>ETH/USD</small>
            <div id="eth" class="loading">Fetching...</div>
        </div>
    </div>

    <div class="link-tree">
        <a href="#" class="btn"><span>🎮</span> Free Fire Profile</a>
        <a href="#" class="btn"><span>📈</span> My NFT Collection</a>
        <a href="#" class="btn"><span>🔥</span> Broken Anime List</a>
    </div>

    <script>
        async function getPrices() {
            try {
                const res = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd');
                const data = await res.json();
                document.getElementById('btc').innerHTML = `<span class="price">$${data.bitcoin.usd.toLocaleString()}</span>`;
                document.getElementById('eth').innerHTML = `<span class="price">$${data.ethereum.usd.toLocaleString()}</span>`;
            } catch (e) {
                document.getElementById('btc').innerText = "Offline";
            }
        }
        getPrices();
        setInterval(getPrices, 60000); // Updates every minute
    </script>

</body>
</html>
